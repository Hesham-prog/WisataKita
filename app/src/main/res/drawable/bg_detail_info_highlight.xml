<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#222C4626" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#284F8F35"
                android:centerColor="#141A1918"
                android:endColor="#1020B8C7" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1dp"
                android:color="#594F8F35" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</layer-list>
