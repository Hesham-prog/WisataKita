<?xml version="1.0" encoding="utf-8"?>
<!-- Glassmorphism variant with green tint — for category chips, featured section headers -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2A4F8F35" /><!-- green 16% -->
            <corners android:radius="50dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="#664F8F35" /><!-- green 40% border -->
            <corners android:radius="50dp" />
        </shape>
    </item>
</layer-list>
