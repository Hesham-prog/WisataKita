<?xml version="1.0" encoding="utf-8"?>
<!--
    Glassmorphism "frosted glass" surface.
    Usage: android:background="@drawable/bg_glassmorphism"
    Works best on dark (charcoal) backgrounds.
    NOTE: True blur requires RenderScript/RenderEffect in Kotlin; this is the
    color-layer approximation that looks authentic at the given opacity.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Frosted dark base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_surface" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Subtle white sheen (top highlight) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#33FFFFFF"
                android:centerColor="#0FE3A33A"
                android:endColor="#00292825" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item android:top="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#241FFFFF"
                android:centerColor="#00000000"
                android:endColor="#1AE3A33A" />
            <corners android:radius="19dp" />
        </shape>
    </item>

    <!-- Border stroke -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="@color/glass_border" />
            <corners android:radius="20dp" />
        </shape>
    </item>

</layer-list>
