<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#241FFFFF" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#1F20B8C7"
                android:centerColor="#101A1918"
                android:endColor="#22E3A33A" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_border" />
        </shape>
    </item>
</layer-list>
