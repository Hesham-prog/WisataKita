<?xml version="1.0" encoding="utf-8"?>
<!-- Turquoise-tinted glassmorphism chip — for location, weather, secondary info chips -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2A20B8C7" /><!-- turquoise 16% -->
            <corners android:radius="50dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="#6620B8C7" /><!-- turquoise 40% border -->
            <corners android:radius="50dp" />
        </shape>
    </item>
</layer-list>
