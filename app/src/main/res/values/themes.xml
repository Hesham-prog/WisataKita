<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  BASE THEME — Edge-to-edge dark, no action bar                  -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <style name="Theme.WisataKita" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/turquoise_primary</item>
        <item name="colorSecondaryVariant">@color/turquoise_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surfaces -->
        <item name="colorSurface">@color/charcoal_medium</item>
        <item name="colorOnSurface">@color/cream_primary</item>
        <item name="colorBackground">@color/charcoal_primary</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="android:colorBackground">@color/charcoal_primary</item>
        <item name="android:windowBackground">@color/charcoal_primary</item>

        <!-- System bars — fully transparent for edge-to-edge -->
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Typography -->
        <item name="fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>

        <!-- Material component overrides -->
        <item name="materialButtonStyle">@style/Widget.WisataKita.Button</item>
        <item name="chipStyle">@style/Widget.WisataKita.Chip</item>
        <item name="bottomSheetDialogTheme">@style/Theme.WisataKita.BottomSheet</item>
        <item name="snackbarStyle">@style/Widget.WisataKita.Snackbar</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  ACTIVITY THEMES                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Splash — pure black for SplashScreen API compat -->
    <style name="Theme.WisataKita.Splash" parent="Theme.WisataKita">
        <item name="android:windowBackground">@color/charcoal_dark</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- No action bar — Login, Register, Onboarding, Profile setup -->
    <style name="Theme.WisataKita.NoActionBar" parent="Theme.WisataKita">
        <item name="android:windowBackground">@color/charcoal_primary</item>
    </style>

    <!-- App screens — with activity transition animations -->
    <style name="Theme.WisataKita.App" parent="Theme.WisataKita">
        <item name="android:windowBackground">@color/charcoal_primary</item>
        <item name="android:windowAnimationStyle">@style/ActivityAnimation.Fade</item>
    </style>

    <!-- Detail / Gallery — edge-to-edge immersive -->
    <style name="Theme.WisataKita.Immersive" parent="Theme.WisataKita">
        <item name="android:windowBackground">@color/charcoal_dark</item>
        <item name="android:windowAnimationStyle">@style/ActivityAnimation.SlideUp</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  ACTIVITY TRANSITION ANIMATIONS                                  -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <style name="ActivityAnimation.Fade" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/fade_in_slide_up</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/fade_out_slide_down</item>
    </style>

    <style name="ActivityAnimation.SlideUp" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_up</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out_scale</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_down</item>
    </style>

    <!-- Legacy alias used in existing manifest entries -->
    <style name="ActivityAnimation" parent="ActivityAnimation.Fade"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  WIDGET OVERRIDES                                                -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <style name="Widget.WisataKita.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">50dp</item>
        <item name="backgroundTint">@color/green_primary</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.WisataKita.Button.Gold" parent="Widget.WisataKita.Button">
        <item name="backgroundTint">@color/gold_primary</item>
        <item name="android:textColor">@color/charcoal_primary</item>
    </style>

    <style name="Widget.WisataKita.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">50dp</item>
        <item name="strokeColor">@color/green_primary</item>
        <item name="android:textColor">@color/green_primary</item>
    </style>

    <style name="Widget.WisataKita.Chip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textSize">13sp</item>
        <item name="chipBackgroundColor">@color/glass_tint_green</item>
        <item name="chipStrokeColor">@color/glass_border</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/cream_primary</item>
        <item name="checkedIconTint">@color/gold_primary</item>
        <item name="checkedBackgroundColor">@color/glass_tint_green</item>
        <item name="cornerRadius">20dp</item>
    </style>

    <style name="Theme.WisataKita.BottomSheet" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.WisataKita.BottomSheet</item>
    </style>

    <style name="Widget.WisataKita.BottomSheet" parent="Widget.MaterialComponents.BottomSheet">
        <item name="backgroundTint">@color/charcoal_medium</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.WisataKita.BottomSheet</item>
    </style>

    <style name="ShapeAppearance.WisataKita.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="Widget.WisataKita.Snackbar" parent="Widget.MaterialComponents.Snackbar">
        <item name="android:background">@drawable/bg_snackbar</item>
        <item name="actionTextColorAlpha">1</item>
    </style>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  TEXT APPEARANCES — Typography System                            -->
    <!--  Fraunces (Display) · Plus Jakarta Sans (Body) · Bebas (Nums)  -->
    <!-- ═══════════════════════════════════════════════════════════════ -->

    <!-- Display — Fraunces, hero titles -->
    <style name="TextAppearance.WisataKita.Display" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="fontFamily">@font/fraunces_bold</item>
        <item name="android:fontFamily">@font/fraunces_bold</item>
        <item name="android:textSize">40sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">-0.02</item>
        <item name="android:lineSpacingMultiplier">1.1</item>
    </style>

    <!-- Headline — Fraunces, screen titles -->
    <style name="TextAppearance.WisataKita.Headline1" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="fontFamily">@font/fraunces_bold</item>
        <item name="android:fontFamily">@font/fraunces_bold</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.WisataKita.Headline2" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="fontFamily">@font/fraunces_semibold</item>
        <item name="android:fontFamily">@font/fraunces_semibold</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.WisataKita.Headline3" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="fontFamily">@font/fraunces_semibold</item>
        <item name="android:fontFamily">@font/fraunces_semibold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Body — Plus Jakarta Sans -->
    <style name="TextAppearance.WisataKita.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/cream_primary</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="TextAppearance.WisataKita.Body2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <!-- Label — Plus Jakarta Sans SemiBold, buttons / chips -->
    <style name="TextAppearance.WisataKita.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/cream_primary</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="TextAppearance.WisataKita.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/colorTextHint</item>
    </style>

    <!-- Numeric — Bebas Neue, ratings / distances / prices -->
    <style name="TextAppearance.WisataKita.Numeric" parent="TextAppearance.MaterialComponents.Body1">
        <item name="fontFamily">@font/bebas_neue</item>
        <item name="android:fontFamily">@font/bebas_neue</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/gold_primary</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.WisataKita.NumericLarge" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="fontFamily">@font/bebas_neue</item>
        <item name="android:fontFamily">@font/bebas_neue</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/gold_primary</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <!-- Button text -->
    <style name="TextAppearance.WisataKita.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans_semibold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

</resources>
