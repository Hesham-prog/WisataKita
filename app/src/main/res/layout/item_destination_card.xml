<?xml version="1.0" encoding="utf-8"?>
<!-- Card (magazine) mode — wider landscape card with full description -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/charcoal_medium">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Large image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp">

            <ImageView
                android:id="@+id/iv_card_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@string/app_name"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_card_overlay"/>

            <!-- Category + Rating overlay on image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tv_card_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alam"
                    android:textSize="11sp"
                    android:fontFamily="@font/plus_jakarta_sans_semibold"
                    android:textColor="@color/charcoal_primary"
                    android:background="@drawable/bg_gold_button"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

                <android.widget.Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_glassmorphism"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_star"
                        android:contentDescription="Rating"/>

                    <TextView
                        android:id="@+id/tv_card_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.8"
                        android:textSize="14sp"
                        android:fontFamily="@font/bebas_neue"
                        android:textColor="@color/gold_primary"
                        android:layout_marginStart="4dp"/>

                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Text content below image -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tv_card_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Candi Borobudur"
                android:textSize="20sp"
                android:fontFamily="@font/fraunces_bold"
                android:textColor="@color/white"
                android:lineSpacingMultiplier="1.1"
                android:letterSpacing="-0.01"/>

            <TextView
                android:id="@+id/tv_card_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Magelang, Jawa Tengah"
                android:textSize="13sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_card_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Deskripsi singkat..."
                android:textSize="13sp"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginTop="10dp"
                android:maxLines="3"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.5"/>

            <TextView
                android:id="@+id/tv_card_ticket"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Rp 50.000"
                android:textSize="16sp"
                android:fontFamily="@font/bebas_neue"
                android:textColor="@color/gold_primary"
                android:letterSpacing="0.04"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
