<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="120dp">

        <!-- ═══════════════════ HERO HEADER ═══════════════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">

            <!-- Background gradient -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gradient_hero"/>

            <!-- Subtle overlay for text readability -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/scrim_light"/>

            <!-- Header content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="24dp"
                android:paddingTop="56dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Time-of-day greeting -->
                        <TextView
                            android:id="@+id/tv_greeting_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selamat Pagi"
                            android:textSize="14sp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:textColor="#CCF2D8B3"
                            android:letterSpacing="0.06"/>

                        <!-- Name greeting -->
                        <TextView
                            android:id="@+id/tv_greeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Halo, Penjelajah!"
                            android:textSize="26sp"
                            android:fontFamily="@font/fraunces_bold"
                            android:textColor="@color/white"
                            android:letterSpacing="-0.01"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/greeting_subtitle"
                            android:textSize="13sp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:textColor="#99F2D8B3"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <!-- Logo + Music button -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageButton
                            android:id="@+id/btn_music"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_music_on"
                            android:background="@drawable/bg_glassmorphism"
                            android:padding="10dp"
                            android:contentDescription="@string/content_desc_music"
                            android:layout_marginEnd="10dp"/>

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_logo"
                            android:contentDescription="@string/app_name"/>

                    </LinearLayout>
                </LinearLayout>

                <!-- Search bar (glassmorphism) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_search"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#80292825">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_search"
                            android:tint="@color/cream_primary"
                            android:alpha="0.7"
                            android:contentDescription="Cari"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="@string/search_hint"
                            android:textSize="14sp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:textColor="#66F2D8B3"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </FrameLayout>

        <!-- ═══════════════════ FEATURED DESTINATIONS ═══════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp">

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/section_featured"
                    android:textSize="20sp"
                    android:fontFamily="@font/fraunces_semibold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/tv_see_all_featured"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_see_all"
                    android:textSize="13sp"
                    android:fontFamily="@font/plus_jakarta_sans_semibold"
                    android:textColor="@color/turquoise_primary"/>

            </LinearLayout>

            <!-- Horizontal RecyclerView — Featured (Card mode) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_featured"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:paddingStart="24dp"
                android:paddingEnd="8dp"
                android:clipToPadding="false"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

        </LinearLayout>

        <!-- ═══════════════════ CATEGORY CHIPS ═══════════════════ -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/ll_categories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"/>

        </HorizontalScrollView>

        <!-- ═══════════════════ NEAREST DESTINATIONS ═══════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/section_nearby"
                    android:textSize="20sp"
                    android:fontFamily="@font/fraunces_semibold"
                    android:textColor="@color/white"/>

                <TextView
                    android:id="@+id/tv_see_all_nearby"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_see_all"
                    android:textSize="13sp"
                    android:fontFamily="@font/plus_jakarta_sans_semibold"
                    android:textColor="@color/turquoise_primary"/>

            </LinearLayout>

            <!-- Vertical RecyclerView — Nearby (List mode) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_nearby"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>

        <!-- ═══════════════════ ABOUT INDONESIA CARD ═══════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_about_indonesia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="28dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/charcoal_medium">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Indonesia flag-inspired accent bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    <View
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="#CC2E2E"/>
                    <View
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="#FFFFFF"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🇮🇩 Tentang Indonesia"
                    android:textSize="18sp"
                    android:fontFamily="@font/fraunces_semibold"
                    android:textColor="@color/white"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tv_about_indonesia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/about_indonesia_body"
                    android:textSize="14sp"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColor="@color/colorTextSecondary"
                    android:lineSpacingMultiplier="1.6"
                    android:maxLines="4"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tv_about_read_more"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/about_indonesia_read_more"
                    android:textSize="13sp"
                    android:fontFamily="@font/plus_jakarta_sans_semibold"
                    android:textColor="@color/turquoise_primary"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
