<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.motion.widget.MotionLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/motionDetail"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    app:layoutDescription="@xml/scene_detail">

    <com.wisatakita.app.MorphingImageView
        android:id="@+id/ivDetailImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/charcoal_dark"
        android:scaleType="centerCrop" />

    <View
        android:id="@+id/heroGoldOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0"
        android:background="@color/gold_surface" />

    <com.wisatakita.app.RainOverlayView
        android:id="@+id/rainOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <View
        android:id="@+id/heroScrim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_detail_hero_scrim" />

    <View
        android:id="@+id/toolbarScrim"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:alpha="0"
        android:background="@color/charcoal_dark" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_glassmorphism"
        android:contentDescription="@string/content_desc_back"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_revert"
        android:tint="@color/cream_primary" />

    <TextView
        android:id="@+id/tvDetailTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/fraunces_bold"
        android:includeFontPadding="false"
        android:lineSpacingExtra="2dp"
        android:maxLines="2"
        android:text="Nama Destinasi"
        android:textColor="@color/white"
        android:textSize="30sp" />

    <LinearLayout
        android:id="@+id/layoutFabActions"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogleMaps"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/btn_open_maps"
            android:textAllCaps="false"
            android:textColor="@color/cream_primary"
            android:textSize="12sp"
            app:backgroundTint="@color/glass_surface"
            app:cornerRadius="22dp"
            app:icon="@android:drawable/ic_dialog_map"
            app:iconTint="@color/turquoise_primary"
            app:strokeColor="@color/glass_border"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWriteReview"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/btn_write_review"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text=""
            app:backgroundTint="@color/glass_surface"
            app:cornerRadius="22dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/gold_primary"
            app:strokeColor="@color/glass_border"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareDestination"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/btn_share"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text=""
            app:backgroundTint="@color/glass_surface"
            app:cornerRadius="22dp"
            app:icon="@android:drawable/ic_menu_share"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/cream_primary"
            app:strokeColor="@color/glass_border"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/detailScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="112dp"
        android:paddingTop="535dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDetailContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/glass_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/glass_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvDetailLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans_semibold"
                        android:text="Lokasi"
                        android:textColor="@color/turquoise_primary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvDetailAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="Alamat lengkap"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvDetailMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/bebas_neue"
                        android:letterSpacing="0.04"
                        android:text="Kategori - Rating"
                        android:textColor="@color/gold_primary"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/tvTicketInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:text="Harga tiket dan jam buka"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="12sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardWeather"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardBackgroundColor="@color/glass_tint_turquoise"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/glass_border"
                        app:strokeWidth="1dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="72dp"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/tvWeatherIcon"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:fontFamily="@font/bebas_neue"
                                android:gravity="center"
                                android:text="--"
                                android:textColor="@color/gold_primary"
                                android:textSize="34sp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tvWeatherInfo"
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_marginStart="12dp"
                                android:fontFamily="@font/plus_jakarta_sans"
                                android:gravity="center_vertical"
                                android:text="@string/weather_loading"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                app:layout_constraintBottom_toBottomOf="@id/tvWeatherIcon"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@id/tvWeatherIcon"
                                app:layout_constraintTop_toTopOf="@id/tvWeatherIcon" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="22dp"
                        android:layout_marginBottom="20dp"
                        android:background="@color/glass_border" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/fraunces_semibold"
                        android:text="Foto Lokasi"
                        android:textColor="@color/white"
                        android:textSize="17sp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="22dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/llGallery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/fraunces_semibold"
                        android:text="Tempat Sekitar"
                        android:textColor="@color/white"
                        android:textSize="17sp" />

                    <LinearLayout
                        android:id="@+id/llNearbyPlaces"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="22dp"
                        android:orientation="vertical" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/fraunces_semibold"
                        android:text="Tentang Destinasi"
                        android:textColor="@color/white"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/tvDetailDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:lineSpacingExtra="5dp"
                        android:text="Deskripsi destinasi wisata..."
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvPromoInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_chip_glass_green"
                        android:fontFamily="@font/plus_jakarta_sans_semibold"
                        android:lineSpacingExtra="4dp"
                        android:padding="14dp"
                        android:text="Promo wisata"
                        android:textColor="@color/cream_primary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvTransportInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:lineSpacingExtra="4dp"
                        android:text="Info transportasi"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvEmergencyInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:lineSpacingExtra="4dp"
                        android:text="Kontak darurat"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="22dp"
                        android:layout_marginBottom="20dp"
                        android:background="@color/glass_border" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/fraunces_semibold"
                        android:text="Fun Facts"
                        android:textColor="@color/white"
                        android:textSize="17sp" />

                    <LinearLayout
                        android:id="@+id/llFunFacts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/tvReviews"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:lineSpacingExtra="4dp"
                        android:text="Review pengunjung"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPesanTiket"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:fontFamily="@font/plus_jakarta_sans_semibold"
        android:text="@string/btn_buy_ticket"
        android:textAllCaps="false"
        android:textColor="@color/charcoal_primary"
        android:textSize="16sp"
        app:backgroundTint="@color/gold_primary"
        app:cornerRadius="28dp" />

</androidx.constraintlayout.motion.widget.MotionLayout>
