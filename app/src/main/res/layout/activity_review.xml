<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.wisatakita.app.TopographicBackgroundView
        android:id="@+id/topographicBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_glassmorphism"
        android:contentDescription="@string/content_desc_back"
        android:padding="12dp"
        android:src="@drawable/ic_back_premium"
        android:tint="@color/cream_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvReviewTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="20dp"
        android:fontFamily="@font/fraunces_bold"
        android:text="@string/review_title"
        android:textColor="@color/white"
        android:textSize="25sp"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <ScrollView
        android:id="@+id/reviewScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="28dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/glass_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/glass_border"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/ivDestination"
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:background="@color/charcoal_medium"
                        android:scaleType="centerCrop" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDestinationName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/fraunces_bold"
                            android:text="@string/detail_title_placeholder"
                            android:textColor="@color/white"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/tvDestinationLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/plus_jakarta_sans"
                            android:text="@string/detail_location_placeholder"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/plus_jakarta_sans_semibold"
                android:text="@string/review_rating_label"
                android:textColor="@color/cream_primary"
                android:textSize="14sp" />

            <com.wisatakita.app.GununRatingView
                android:id="@+id/ratingGunung"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvRatingValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bebas_neue"
                android:text="0/5"
                android:textColor="@color/gold_primary"
                android:textSize="24sp" />

            <EditText
                android:id="@+id/etReview"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="18dp"
                android:background="@color/transparent"
                android:fontFamily="@font/plus_jakarta_sans"
                android:gravity="top"
                android:hint="@string/review_body_hint"
                android:inputType="textMultiLine|textCapSentences"
                android:padding="0dp"
                android:textColor="@color/white"
                android:textColorHint="@color/colorTextHint"
                android:textSize="15sp" />

            <View
                android:id="@+id/reviewUnderline"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:alpha="0.55"
                android:background="@color/gold_primary"
                android:pivotX="0"
                android:scaleX="0.72" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCamera"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/plus_jakarta_sans_semibold"
                    android:text="@string/gallery_take_photo"
                    android:textAllCaps="false"
                    android:textColor="@color/cream_primary"
                    app:backgroundTint="@color/glass_surface"
                    app:cornerRadius="23dp"
                    app:icon="@drawable/ic_camera_premium"
                    app:iconTint="@color/turquoise_primary"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGallery"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/plus_jakarta_sans_semibold"
                    android:text="@string/gallery_pick_photo"
                    android:textAllCaps="false"
                    android:textColor="@color/cream_primary"
                    app:backgroundTint="@color/glass_surface"
                    app:cornerRadius="23dp"
                    app:icon="@drawable/ic_gallery_premium"
                    app:iconTint="@color/gold_primary"
                    app:strokeColor="@color/glass_border"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPhotoPreview"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/glass_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/glass_border"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivAttachedPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <ImageButton
                        android:id="@+id/btnDeletePhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="10dp"
                        android:background="@drawable/bg_glassmorphism"
                        android:contentDescription="@string/close"
                        android:padding="10dp"
                        android:src="@drawable/ic_close_premium"
                        android:tint="@color/white" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitReview"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="26dp"
                android:fontFamily="@font/plus_jakarta_sans_semibold"
                android:text="@string/review_submit"
                android:textAllCaps="false"
                android:textColor="@color/charcoal_primary"
                android:textSize="16sp"
                app:backgroundTint="@color/gold_primary"
                app:cornerRadius="28dp" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
