<?xml version="1.0" encoding="utf-8"?>
<!-- Grid mode destination item — square image with info overlay -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:layout_margin="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/iv_grid_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@string/app_name"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_card_overlay"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tv_grid_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nama Destinasi"
                android:textSize="13sp"
                android:fontFamily="@font/fraunces_bold"
                android:textColor="@color/white"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/ic_star"
                    android:contentDescription="Rating"/>

                <TextView
                    android:id="@+id/tv_grid_rating"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="4.8"
                    android:textSize="11sp"
                    android:fontFamily="@font/bebas_neue"
                    android:textColor="@color/gold_primary"
                    android:layout_marginStart="3dp"/>

            </LinearLayout>
        </LinearLayout>

    </FrameLayout>
</androidx.cardview.widget.CardView>
