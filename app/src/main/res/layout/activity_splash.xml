<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/charcoal_dark">

    <!-- Background gradient bloom -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_splash_bloom"
        android:alpha="0.35"/>

    <!-- Lottie Logo Animation -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_splash_logo"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="center"
        android:layout_marginBottom="64dp"
        app:lottie_autoPlay="false"
        app:lottie_loop="false"
        app:lottie_rawRes="@raw/lottie_splash_logo"/>

    <!-- App Name -->
    <TextView
        android:id="@+id/tv_splash_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="180dp"
        android:text="@string/app_name"
        android:textSize="42sp"
        android:fontFamily="@font/fraunces_bold"
        android:textColor="@color/white"
        android:letterSpacing="-0.02"
        android:alpha="0"/>

    <!-- Tagline -->
    <TextView
        android:id="@+id/tv_splash_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="252dp"
        android:text="@string/app_tagline"
        android:textSize="16sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:textColor="@color/cream_primary"
        android:letterSpacing="0.08"
        android:alpha="0"/>

    <!-- Version -->
    <TextView
        android:id="@+id/tv_splash_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:text="© 2025 WisataKita"
        android:textSize="12sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:textColor="@color/colorTextHint"/>

</FrameLayout>
