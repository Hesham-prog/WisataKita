<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:clipToPadding="false"
    android:paddingBottom="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="56dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- Centered avatar with glow wrapper (using frame or simple margin) -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                
                <!-- Simple glow effect behind avatar -->
                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_splash_bloom"
                    android:alpha="0.4" />

                <com.wisatakita.app.PassportPhotoView
                    android:id="@+id/ivPassportPhoto"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_logo" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:layout_marginStart="12dp"
                android:ellipsize="end"
                android:fontFamily="@font/fraunces_bold"
                android:gravity="center"
                android:maxLines="2"
                android:text="@string/home_default_user"
                android:textColor="@color/white"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta_sans"
                android:maxLines="1"
                android:text="-"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvStatsPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_gold_button"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta_sans_semibold"
                android:maxLines="1"
                android:paddingBottom="8dp"
                android:paddingEnd="16dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:text="@string/profile_stats_placeholder"
                android:textColor="@color/charcoal_dark"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginTop="28dp"
            app:cardBackgroundColor="@color/charcoal_dark"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:strokeColor="@color/gold_primary"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/fraunces_semibold"
                    android:text="@string/profile_stats_title"
                    android:textColor="@color/white"
                    android:textSize="18sp" />

                <com.github.mikephil.charting.charts.RadarChart
                    android:id="@+id/radarCategory"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/rowNotificationSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_profile_row_flat"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/profile_notification_settings"
            android:textColor="@color/cream_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/rowLanguageSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_profile_row_flat"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/profile_language_settings"
            android:textColor="@color/cream_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/rowTeam"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_profile_row_flat"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/profile_about_team"
            android:textColor="@color/cream_primary"
            android:textSize="14sp" />

        <FrameLayout
            android:id="@+id/teamInlineContainer"
            android:layout_width="match_parent"
            android:layout_height="430dp"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:text="@string/profile_logout"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/color_error"
            app:cornerRadius="26dp" />
    </LinearLayout>
</ScrollView>
