<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:clipToPadding="false"
    android:paddingBottom="220dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="56dp"
        android:paddingEnd="20dp"
        android:paddingBottom="220dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.wisatakita.app.PassportPhotoView
                android:id="@+id/ivPassportPhoto"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/ic_logo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/groupLanguage"
                android:layout_width="122dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_language_toggle"
                android:padding="3dp"
                app:checkedButton="@id/btnLangId"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangId"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="58dp"
                    android:layout_height="38dp"
                    android:fontFamily="@font/plus_jakarta_sans_semibold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:text="ID"
                    android:textAllCaps="false"
                    android:textColor="@color/language_segment_text"
                    android:textSize="12sp"
                    app:backgroundTint="@color/language_segment_tint"
                    app:cornerRadius="19dp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangEn"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="58dp"
                    android:layout_height="38dp"
                    android:fontFamily="@font/plus_jakarta_sans_semibold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp"
                    android:text="EN"
                    android:textAllCaps="false"
                    android:textColor="@color/language_segment_text"
                    android:textSize="12sp"
                    app:backgroundTint="@color/language_segment_tint"
                    app:cornerRadius="19dp"
                    app:strokeWidth="0dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:id="@+id/tvProfileName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="12dp"
                android:ellipsize="end"
                android:fontFamily="@font/fraunces_bold"
                android:maxLines="1"
                android:text="@string/home_default_user"
                android:textColor="@color/white"
                android:textSize="25sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivPassportPhoto"
                app:layout_constraintTop_toBottomOf="@id/groupLanguage" />

            <TextView
                android:id="@+id/tvProfileEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta_sans"
                android:maxLines="1"
                android:text="-"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivPassportPhoto"
                app:layout_constraintTop_toBottomOf="@id/tvProfileName" />

            <TextView
                android:id="@+id/tvStatsPill"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_chip_glass_turquoise"
                android:ellipsize="end"
                android:fontFamily="@font/plus_jakarta_sans_semibold"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:paddingTop="7dp"
                android:paddingEnd="12dp"
                android:paddingBottom="7dp"
                android:text="@string/profile_stats_placeholder"
                android:textColor="@color/cream_primary"
                android:textSize="10sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivPassportPhoto"
                app:layout_constraintTop_toBottomOf="@id/tvProfileEmail" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/glass_surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/glass_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/fraunces_semibold"
                    android:text="@string/profile_stats_title"
                    android:textColor="@color/white"
                    android:textSize="18sp" />

                <com.github.mikephil.charting.charts.RadarChart
                    android:id="@+id/radarCategory"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/rowNotificationSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_profile_row_flat"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/profile_notification_settings"
            android:textColor="@color/cream_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/rowLanguageSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_profile_row_flat"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/profile_language_settings"
            android:textColor="@color/cream_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/rowTeam"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_profile_row_flat"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/profile_about_team"
            android:textColor="@color/cream_primary"
            android:textSize="14sp" />

        <FrameLayout
            android:id="@+id/teamInlineContainer"
            android:layout_width="match_parent"
            android:layout_height="430dp"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/plus_jakarta_sans_semibold"
            android:text="@string/profile_logout"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:backgroundTint="@color/color_error"
            app:cornerRadius="26dp" />
    </LinearLayout>
</ScrollView>
