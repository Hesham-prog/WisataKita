<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/charcoal_primary">

    <!-- Lottie illustration -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_onboarding"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/lottie_onboarding_explore"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintBottom_toTopOf="@id/tv_onboarding_title"
        android:layout_marginTop="64dp"
        android:layout_marginBottom="32dp"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tv_onboarding_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:text="Ribuan Destinasi Menunggumu"
        android:textSize="28sp"
        android:fontFamily="@font/fraunces_bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:lineSpacingMultiplier="1.15"
        android:letterSpacing="-0.01"
        android:alpha="0"
        android:translationY="40dp"
        app:layout_constraintTop_toBottomOf="@id/lottie_onboarding"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_onboarding_body"/>

    <!-- Body -->
    <TextView
        android:id="@+id/tv_onboarding_body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="16dp"
        android:text="Dari pantai eksotis Raja Ampat hingga megahnya Candi Borobudur — semua ada di satu tempat."
        android:textSize="15sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:textColor="@color/colorTextSecondary"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:alpha="0"
        android:translationY="30dp"
        app:layout_constraintTop_toBottomOf="@id/tv_onboarding_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
