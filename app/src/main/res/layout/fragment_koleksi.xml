<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical"
    android:paddingTop="58dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:fontFamily="@font/fraunces_bold"
        android:includeFontPadding="false"
        android:lineSpacingExtra="2dp"
        android:maxLines="2"
        android:text="@string/koleksi_passport_title"
        android:textColor="@color/white"
        android:textSize="25sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="20dp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:text="@string/koleksi_passport_subtitle"
        android:textColor="@color/colorTextSecondary"
        android:textSize="13sp" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabKoleksi"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="18dp"
        android:background="@color/transparent"
        app:tabIndicatorColor="@color/gold_primary"
        app:tabIndicatorHeight="2dp"
        app:tabRippleColor="@color/glass_tint_green"
        app:tabSelectedTextColor="@color/gold_primary"
        app:tabTextColor="@color/colorTextSecondary" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerKoleksi"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
