<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <!--
        Single seamless transition: start → end.
        OnSwipe syncs this transition 1:1 with the scroll view so the
        header collapses perfectly with the user's finger.
        No more manual Kotlin scroll listener needed.
    -->
    <Transition
        motion:constraintSetEnd="@id/end"
        motion:constraintSetStart="@id/start"
        motion:duration="500"
        motion:motionInterpolator="easeInOut">

        <OnSwipe
            motion:dragDirection="dragUp"
            motion:onTouchUp="decelerate"
            motion:touchAnchorId="@+id/detailScroll"
            motion:touchAnchorSide="top" />

        <KeyFrameSet>
            <!-- Title starts scaling down at ~30% progress -->
            <KeyAttribute
                android:textSize="22sp"
                motion:framePosition="60"
                motion:motionTarget="@id/tvDetailTitle" />

            <!-- Toolbar scrim fades in between 40-80% -->
            <KeyAttribute
                android:alpha="0"
                motion:framePosition="35"
                motion:motionTarget="@id/toolbarScrim" />
            <KeyAttribute
                android:alpha="0.7"
                motion:framePosition="75"
                motion:motionTarget="@id/toolbarScrim" />

            <!-- layoutFabActions fades out at 50-70% -->
            <KeyAttribute
                android:alpha="1"
                motion:framePosition="45"
                motion:motionTarget="@id/layoutFabActions" />
            <KeyAttribute
                android:alpha="0"
                motion:framePosition="68"
                motion:motionTarget="@id/layoutFabActions" />

            <!-- musicOrb fades out gently -->
            <KeyAttribute
                android:alpha="1"
                motion:framePosition="50"
                motion:motionTarget="@id/musicOrb" />
            <KeyAttribute
                android:alpha="0"
                motion:framePosition="80"
                motion:motionTarget="@id/musicOrb" />
        </KeyFrameSet>
    </Transition>

    <!-- ═══════════════════════════ START ═══════════════════════════ -->
    <ConstraintSet android:id="@+id/start">
        <Constraint android:id="@id/ivDetailImage">
            <Layout
                android:layout_width="0dp"
                android:layout_height="0dp"
                motion:layout_constraintDimensionRatio="H,100:55"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
            <CustomAttribute
                motion:attributeName="scaleType"
                motion:customStringValue="centerCrop" />
        </Constraint>

        <Constraint android:id="@id/heroGoldOverlay">
            <Layout
                android:layout_width="0dp"
                android:layout_height="0dp"
                motion:layout_constraintBottom_toBottomOf="@id/ivDetailImage"
                motion:layout_constraintEnd_toEndOf="@id/ivDetailImage"
                motion:layout_constraintStart_toStartOf="@id/ivDetailImage"
                motion:layout_constraintTop_toTopOf="@id/ivDetailImage" />
            <PropertySet android:alpha="0" />
        </Constraint>

        <Constraint android:id="@id/rainOverlay">
            <Layout
                android:layout_width="0dp"
                android:layout_height="0dp"
                motion:layout_constraintBottom_toBottomOf="@id/ivDetailImage"
                motion:layout_constraintEnd_toEndOf="@id/ivDetailImage"
                motion:layout_constraintStart_toStartOf="@id/ivDetailImage"
                motion:layout_constraintTop_toTopOf="@id/ivDetailImage" />
        </Constraint>

        <Constraint android:id="@id/heroScrim">
            <Layout
                android:layout_width="0dp"
                android:layout_height="0dp"
                motion:layout_constraintBottom_toBottomOf="@id/ivDetailImage"
                motion:layout_constraintEnd_toEndOf="@id/ivDetailImage"
                motion:layout_constraintStart_toStartOf="@id/ivDetailImage"
                motion:layout_constraintTop_toTopOf="@id/ivDetailImage" />
        </Constraint>

        <Constraint android:id="@id/toolbarScrim">
            <Layout
                android:layout_width="0dp"
                android:layout_height="56dp"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
            <PropertySet android:alpha="0" />
        </Constraint>

        <Constraint android:id="@id/btnBack">
            <Layout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
        </Constraint>

        <Constraint android:id="@id/musicOrb">
            <Layout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="6dp"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
            <PropertySet android:alpha="1" />
        </Constraint>

        <Constraint android:id="@id/tvDetailTitle">
            <Layout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="28dp"
                motion:layout_constraintBottom_toBottomOf="@id/ivDetailImage"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent" />
            <PropertySet android:alpha="1" />
            <CustomAttribute
                motion:attributeName="textSize"
                motion:customFloatValue="30" />
        </Constraint>

        <Constraint android:id="@id/layoutFabActions">
            <Layout
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="18dp"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toBottomOf="@id/ivDetailImage" />
            <PropertySet android:alpha="1" />
            <Transform android:scaleX="1" android:scaleY="1" />
        </Constraint>

        <Constraint android:id="@id/detailScroll">
            <Layout
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                motion:layout_constraintBottom_toBottomOf="parent"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toBottomOf="@id/layoutFabActions" />
        </Constraint>

        <Constraint android:id="@id/btnPesanTiket">
            <Layout
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="20dp"
                motion:layout_constraintBottom_toBottomOf="parent"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent" />
            <PropertySet android:alpha="0" android:visibility="invisible" />
            <Transform android:translationY="96dp" />
        </Constraint>
    </ConstraintSet>

    <!-- ═══════════════════════════ END ═══════════════════════════ -->
    <ConstraintSet android:id="@+id/end">
        <Constraint android:id="@id/ivDetailImage">
            <Layout
                android:layout_width="0dp"
                android:layout_height="56dp"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
            <CustomAttribute
                motion:attributeName="scaleType"
                motion:customStringValue="centerCrop" />
        </Constraint>

        <Constraint android:id="@id/heroGoldOverlay">
            <Layout
                android:layout_width="0dp"
                android:layout_height="56dp"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
            <PropertySet android:alpha="0.14" />
        </Constraint>

        <Constraint android:id="@id/rainOverlay">
            <Layout
                android:layout_width="0dp"
                android:layout_height="56dp"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
        </Constraint>

        <Constraint android:id="@id/heroScrim">
            <Layout
                android:layout_width="0dp"
                android:layout_height="56dp"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
        </Constraint>

        <Constraint android:id="@id/toolbarScrim">
            <Layout
                android:layout_width="0dp"
                android:layout_height="130dp"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
            <PropertySet android:alpha="1" />
        </Constraint>

        <Constraint android:id="@id/btnBack">
            <Layout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="6dp"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
        </Constraint>

        <Constraint android:id="@id/musicOrb">
            <Layout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="-4dp"
                android:layout_marginEnd="6dp"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
            <PropertySet android:alpha="0" />
        </Constraint>

        <Constraint android:id="@id/tvDetailTitle">
            <Layout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="72dp"
                android:layout_marginEnd="72dp"
                motion:layout_constraintBottom_toBottomOf="@id/btnBack"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toTopOf="@id/btnBack" />
            <PropertySet android:alpha="1" />
            <CustomAttribute
                motion:attributeName="textSize"
                motion:customFloatValue="16" />
        </Constraint>

        <Constraint android:id="@id/layoutFabActions">
            <Layout
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="4dp"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintTop_toTopOf="parent" />
            <PropertySet android:alpha="0" android:visibility="invisible" />
            <Transform android:scaleX="0.75" android:scaleY="0.75" />
        </Constraint>

        <Constraint android:id="@id/detailScroll">
            <Layout
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                motion:layout_constraintBottom_toTopOf="@id/btnPesanTiket"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent"
                motion:layout_constraintTop_toBottomOf="@id/toolbarScrim" />
        </Constraint>

        <Constraint android:id="@id/btnPesanTiket">
            <Layout
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="20dp"
                motion:layout_constraintBottom_toBottomOf="parent"
                motion:layout_constraintEnd_toEndOf="parent"
                motion:layout_constraintStart_toStartOf="parent" />
            <PropertySet android:alpha="1" android:visibility="visible" />
            <Transform android:translationY="0dp" />
        </Constraint>
    </ConstraintSet>
</MotionScene>
